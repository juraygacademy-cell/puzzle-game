<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Slide & Earn Puzzle</title>
<style>
  :root{
    --bg:#050b18;
    --panel:#0d1830;
    --accent:#a8e000;
    --accent2:#2e8fe0;
    --tile:#142544;
    --tile-hover:#1c3258;
    --text:#eef4ff;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    min-height:100vh;
    background:
      radial-gradient(circle at 15% 0%, rgba(46,143,224,0.18), transparent 40%),
      radial-gradient(circle at 85% 10%, rgba(168,224,0,0.10), transparent 35%),
      linear-gradient(180deg, #060c1a, var(--bg) 40%, #03060d);
    color:var(--text);
    font-family:'Segoe UI', Roboto, Arial, sans-serif;
    display:flex;
    flex-direction:column;
    align-items:center;
    padding:24px 12px 60px;
  }
  h1{
    margin:0 0 4px;
    font-size:1.8rem;
    letter-spacing:1px;
    color:var(--text);
  }
  h1 .accent-word{
    color:var(--accent);
  }
  .subtitle{
    color:#7e8bab;
    margin-bottom:18px;
    font-size:0.9rem;
  }
  .topbar{
    display:flex;
    gap:14px;
    align-items:center;
    background:var(--panel);
    border:1px solid #1c3258;
    padding:10px 18px;
    border-radius:14px;
    box-shadow:0 4px 14px rgba(0,0,0,0.45);
    margin-bottom:18px;
    flex-wrap:wrap;
    justify-content:center;
  }
  .stat{
    display:flex;
    align-items:center;
    gap:6px;
    font-weight:600;
    font-size:0.95rem;
  }
  .coin{
    color:var(--accent);
  }
  .level-badge{
    background:var(--accent2);
    color:#04101f;
    padding:3px 10px;
    border-radius:8px;
    font-weight:700;
  }
  .board{
    display:grid;
    gap:6px;
    background:var(--panel);
    border:1px solid #1c3258;
    padding:10px;
    border-radius:16px;
    box-shadow:0 8px 24px rgba(0,0,0,0.5), 0 0 24px rgba(46,143,224,0.08);
    touch-action:none;
  }
  .tile{
    display:flex;
    align-items:center;
    justify-content:center;
    background:var(--tile);
    border-radius:10px;
    font-size:1.4rem;
    font-weight:700;
    cursor:pointer;
    user-select:none;
    transition:transform .08s ease, background .15s ease;
  }
  .tile:hover{background:var(--tile-hover);}
  .tile.empty{
    background:transparent;
    cursor:default;
    box-shadow:none;
  }
  .controls{
    display:flex;
    gap:10px;
    margin-top:18px;
    flex-wrap:wrap;
    justify-content:center;
  }
  button{
    background:var(--accent);
    color:#06140a;
    border:none;
    padding:10px 18px;
    border-radius:10px;
    font-weight:700;
    cursor:pointer;
    font-size:0.95rem;
    transition:transform .1s ease, filter .1s ease;
  }
  button:hover{filter:brightness(1.1);}
  button:active{transform:scale(0.96);}
  button.secondary{
    background:var(--accent2);
    color:#04101f;
  }
  button:disabled{
    background:#2a3650;
    color:#6b7790;
    cursor:not-allowed;
  }
  .panel{
    margin-top:24px;
    background:var(--panel);
    border:1px solid #1c3258;
    border-radius:14px;
    padding:16px 20px;
    width:min(420px,90vw);
    box-shadow:0 4px 14px rgba(0,0,0,0.5);
  }
  .panel h3{
    margin-top:0;
    font-size:1.05rem;
    color:var(--accent2);
  }
  .level-row{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:8px 0;
    border-bottom:1px solid #1c3258;
    font-size:0.9rem;
  }
  .level-row:last-child{border-bottom:none;}
  .toast{
    position:fixed;
    top:20px;
    left:50%;
    transform:translateX(-50%) translateY(-20px);
    background:var(--accent);
    color:#06140a;
    padding:10px 20px;
    border-radius:10px;
    font-weight:700;
    opacity:0;
    transition:all .3s ease;
    pointer-events:none;
    z-index:50;
  }
  .toast.show{
    opacity:1;
    transform:translateX(-50%) translateY(0);
  }
  .small{
    font-size:0.78rem;
    color:#9aa3b8;
    margin-top:6px;
    text-align:center;
  }
  .modal-overlay{
    position:fixed;
    inset:0;
    background:rgba(10,12,18,0.65);
    display:none;
    align-items:center;
    justify-content:center;
    z-index:100;
    backdrop-filter:blur(2px);
  }
  .modal-overlay.show{
    display:flex;
  }
  .modal-box{
    background:linear-gradient(160deg, #0f1d3a, #060c1a);
    border:2px solid var(--accent2);
    border-radius:18px;
    padding:32px 28px;
    width:min(360px, 85vw);
    text-align:center;
    box-shadow:0 12px 40px rgba(0,0,0,0.6), 0 0 30px rgba(46,143,224,0.15);
    animation:popIn .25s ease;
  }
  @keyframes popIn{
    from{transform:scale(0.85); opacity:0;}
    to{transform:scale(1); opacity:1;}
  }
  .modal-emoji{
    font-size:2.6rem;
    margin-bottom:4px;
  }
  .modal-box h2{
    margin:0 0 10px;
    color:var(--accent);
    font-size:1.4rem;
  }
  .modal-text{
    color:var(--text);
    font-size:0.95rem;
    line-height:1.5;
    margin-bottom:20px;
  }
  .modal-text b{
    color:var(--accent2);
    font-size:1.1rem;
  }
  #modalCloseBtn{
    width:100%;
  }
  .discount-scale{
    margin-bottom:20px;
  }
  .discount-pct-display{
    font-size:2.4rem;
    font-weight:800;
    color:var(--accent);
    text-shadow:0 0 18px rgba(168,224,0,0.5);
    margin-bottom:10px;
  }
  .discount-scale-track{
    position:relative;
    height:10px;
    border-radius:6px;
    background:#142544;
    overflow:visible;
  }
  .discount-scale-fill{
    position:absolute;
    left:0; top:0; bottom:0;
    border-radius:6px;
    background:linear-gradient(90deg, var(--accent2), var(--accent));
    width:0%;
    transition:width .6s ease;
  }
  .discount-scale-marker{
    position:absolute;
    top:-6px;
    width:22px;
    height:22px;
    border-radius:50%;
    background:#fff;
    border:3px solid var(--accent);
    left:0%;
    transform:translateX(-50%);
    transition:left .6s ease;
    box-shadow:0 2px 8px rgba(0,0,0,0.5);
  }
  .discount-scale-labels{
    display:flex;
    justify-content:space-between;
    font-size:0.7rem;
    color:#7e8bab;
    margin-top:4px;
  }
</style>
</head>
<body>

<img id="brandLogo" src="data:image/png;base64," alt="Genyx Data Labs" style="max-width:280px;margin-bottom:6px;" />
<h1>🧩 Slide &amp; <span class="accent-word">Earn</span></h1>
<div class="subtitle">Arrange the tiles in order — solve puzzles, earn coins, unlock harder levels!</div>

<div class="topbar">
  <div class="stat"><span class="coin">🪙</span><span id="coinCount">0</span></div>
  <div class="stat">Level <span class="level-badge" id="levelBadge">1</span></div>
  <div class="stat">Moves: <span id="moveCount">0</span></div>
  <div class="stat">⏱ <span id="timer">0s</span></div>
</div>
<div class="small" id="discountMsg" style="margin-bottom:6px;"></div>

<div class="board" id="board"></div>

<div class="controls">
  <button id="shuffleBtn">🔀 Shuffle</button>
  <button id="hintBtn" class="secondary">💡 Hint (5🪙)</button>
</div>
<div class="small" id="msg">Click tiles next to the empty space to slide them.</div>

<div class="panel">
  <h3>Unlock Levels</h3>
  <div id="levelList"></div>
</div>

<div class="toast" id="toast"></div>

<div class="modal-overlay show" id="nameOverlay">
  <div class="modal-box">
    <div class="modal-emoji">👋</div>
    <h2>Welcome to Slide &amp; Earn!</h2>
    <p class="modal-text">Enter your name to begin. Your <b>first puzzle</b> comes with a chance to win a special discount voucher!</p>
    <input id="nameInput" type="text" placeholder="Your name" maxlength="24" autofocus
      style="width:100%;padding:10px 12px;border-radius:10px;border:1px solid #444c5e;background:#1c2230;color:#eef1f7;font-size:0.95rem;margin-bottom:14px;box-sizing:border-box;" />
    <button id="nameStartBtn">Start Playing</button>
  </div>
</div>

<div class="modal-overlay" id="modalOverlay">
  <div class="modal-box">
    <div class="modal-emoji">🎉</div>
    <h2 id="modalTitle">Congrats!</h2>
    <p id="modalText" class="modal-text"></p>
    <div class="discount-scale" id="discountScale" style="display:none;">
      <div class="discount-pct-display" id="discountPctDisplay">10%</div>
      <div class="discount-scale-track">
        <div class="discount-scale-fill" id="discountScaleFill"></div>
        <div class="discount-scale-marker" id="discountScaleMarker"></div>
      </div>
      <div class="discount-scale-labels"><span>10%</span><span>80%</span></div>
    </div>
    <button id="modalCloseBtn">Awesome!</button>
  </div>
</div>


<script>
(function(){
  const LEVELS = [
    {id:1, size:3, cost:0, reward:10, name:"3x3 — Easy"},
    {id:2, size:4, cost:20, reward:25, name:"4x4 — Medium"},
    {id:3, size:5, cost:60, reward:60, name:"5x5 — Hard"},
    {id:4, size:6, cost:150, reward:150, name:"6x6 — Expert"},
  ];

  let state = {
    coins: 0,
    unlocked: [1],
    currentLevel: 1,
    moves: 0,
    size: 3,
    tiles: [],
    emptyIndex: 0,
    seconds: 0,
    timerRunning: false,
    discount: 0,
    playerName: '',
  };

  let timerInterval = null;

  function startTimer(){
    stopTimer();
    state.seconds = 0;
    state.timerRunning = true;
    document.getElementById('timer').textContent = '0s';
    timerInterval = setInterval(()=>{
      state.seconds++;
      document.getElementById('timer').textContent = state.seconds + 's';
    }, 1000);
  }

  function stopTimer(){
    if(timerInterval){ clearInterval(timerInterval); timerInterval = null; }
    state.timerRunning = false;
  }

  // Discount based purely on time, fixed thresholds in seconds
  function computeDiscount(seconds, size, moves){
    if(seconds <= 70) return 0.80;
    if(seconds <= 100) return 0.70;
    if(seconds <= 150) return 0.60;
    if(seconds <= 200) return 0.50;
    if(seconds <= 250) return 0.40;
    if(seconds <= 300) return 0.30;
    if(seconds <= 350) return 0.20;
    return 0.10; // minimum guaranteed voucher beyond that
  }

  const boardEl = document.getElementById('board');
  const coinCountEl = document.getElementById('coinCount');
  const levelBadgeEl = document.getElementById('levelBadge');
  const moveCountEl = document.getElementById('moveCount');
  const levelListEl = document.getElementById('levelList');
  const msgEl = document.getElementById('msg');
  const toastEl = document.getElementById('toast');

  function showToast(text){
    toastEl.textContent = text;
    toastEl.classList.add('show');
    setTimeout(()=> toastEl.classList.remove('show'), 1800);
  }

  function getLevel(id){
    return LEVELS.find(l=>l.id===id);
  }

  function isSolvable(arr, size){
    // count inversions ignoring empty (0)
    const flat = arr.filter(v=>v!==0);
    let inversions = 0;
    for(let i=0;i<flat.length;i++){
      for(let j=i+1;j<flat.length;j++){
        if(flat[i]>flat[j]) inversions++;
      }
    }
    const blankRowFromBottom = size - Math.floor(arr.indexOf(0)/size);
    if(size % 2 === 1){
      return inversions % 2 === 0;
    } else {
      if(blankRowFromBottom % 2 === 0){
        return inversions % 2 === 1;
      } else {
        return inversions % 2 === 0;
      }
    }
  }

  function shuffleArray(size){
    let arr;
    do{
      arr = [...Array(size*size).keys()];
      for(let i=arr.length-1;i>0;i--){
        const j = Math.floor(Math.random()*(i+1));
        [arr[i],arr[j]] = [arr[j],arr[i]];
      }
    } while(!isSolvable(arr, size) || isSolved(arr));
    return arr;
  }

  function isSolved(arr){
    for(let i=0;i<arr.length-1;i++){
      if(arr[i] !== i+1) return false;
    }
    return arr[arr.length-1] === 0;
  }

  function startLevel(levelId){
    const lvl = getLevel(levelId);
    state.currentLevel = levelId;
    state.size = lvl.size;
    state.tiles = shuffleArray(lvl.size);
    state.emptyIndex = state.tiles.indexOf(0);
    state.moves = 0;
    levelBadgeEl.textContent = levelId;
    moveCountEl.textContent = 0;
    msgEl.textContent = `Level ${levelId}: ${lvl.name}. Solve it to earn ${lvl.reward} coins!`;
    const nextLocked = LEVELS.find(l => !state.unlocked.includes(l.id));
    document.getElementById('discountMsg').textContent = (state.discount > 0 && nextLocked)
      ? `🔥 ${Math.round(state.discount*100)}% voucher ready — use it to unlock "${nextLocked.name}"!`
      : '';
    startTimer();
    render();
  }

  function render(){
    const size = state.size;
    boardEl.style.gridTemplateColumns = `repeat(${size}, 64px)`;
    boardEl.style.gridTemplateRows = `repeat(${size}, 64px)`;
    boardEl.innerHTML = '';
    state.tiles.forEach((val, idx)=>{
      const div = document.createElement('div');
      div.className = 'tile' + (val===0 ? ' empty' : '');
      div.textContent = val === 0 ? '' : val;
      div.dataset.idx = idx;
      if(val !== 0){
        div.addEventListener('click', ()=> tryMove(idx));
      }
      boardEl.appendChild(div);
    });
    coinCountEl.textContent = state.coins;
    renderLevels();
  }

  function tryMove(idx){
    const size = state.size;
    const empty = state.emptyIndex;
    const row = Math.floor(idx/size), col = idx%size;
    const erow = Math.floor(empty/size), ecol = empty%size;
    const adjacent = (Math.abs(row-erow)+Math.abs(col-ecol)) === 1;
    if(!adjacent) return;
    [state.tiles[idx], state.tiles[empty]] = [state.tiles[empty], state.tiles[idx]];
    state.emptyIndex = idx;
    state.moves++;
    moveCountEl.textContent = state.moves;
    render();
    if(isSolved(state.tiles)){
      onSolved();
    }
  }

  function onSolved(){
    stopTimer();
    const lvl = getLevel(state.currentLevel);
    state.coins += lvl.reward;
    const nextLocked = LEVELS.find(l => !state.unlocked.includes(l.id));

    // Discount is awarded on EVERY completed puzzle, based on performance and time
    const discount = computeDiscount(state.seconds, state.size, state.moves);
    state.discount = discount;

    msgEl.textContent = `Solved in ${state.seconds}s! +${lvl.reward} coins earned.`;
    document.getElementById('discountMsg').textContent = (discount > 0 && nextLocked)
      ? `🔥 ${Math.round(discount*100)}% voucher ready — use it to unlock "${nextLocked.name}"!`
      : '';
    showModal(discount, lvl.reward, nextLocked, true);
    render();
  }

  function showModal(discount, coinsEarned, nextLocked){
    const overlay = document.getElementById('modalOverlay');
    const title = document.getElementById('modalTitle');
    const text = document.getElementById('modalText');
    const scale = document.getElementById('discountScale');
    const fill = document.getElementById('discountScaleFill');
    const marker = document.getElementById('discountScaleMarker');
    const pctDisplay = document.getElementById('discountPctDisplay');
    const pct = Math.round(discount*100);
    const name = state.playerName || 'Player';

    if(nextLocked){
      title.textContent = `🎉 Congrats, ${name}! You Won a Discount!`;
      text.innerHTML = `You solved it in <b>${state.seconds}s</b> and earned <b>+${coinsEarned} coins</b>!<br><br>
        Based on your speed, you earned a discount voucher for unlocking <b>"${nextLocked.name}"</b>.`;
      const barPos = Math.min(100, Math.max(0, ((pct - 10) / (80 - 10)) * 100));
      scale.style.display = 'block';
      pctDisplay.textContent = pct + '% OFF';
      fill.style.width = barPos + '%';
      marker.style.left = barPos + '%';
    } else {
      title.textContent = `🎉 Nice one, ${name}!`;
      text.innerHTML = `You solved it in <b>${state.seconds}s</b> and earned <b>+${coinsEarned} coins</b>! All levels are already unlocked — great job!`;
      scale.style.display = 'none';
    }
    overlay.classList.add('show');
  }

  document.getElementById('modalCloseBtn').onclick = ()=>{
    document.getElementById('modalOverlay').classList.remove('show');
  };

  function renderLevels(){
    levelListEl.innerHTML = '';
    const nextLockedLevel = LEVELS.find(l => !state.unlocked.includes(l.id));
    LEVELS.forEach(lvl=>{
      const row = document.createElement('div');
      row.className = 'level-row';
      const unlocked = state.unlocked.includes(lvl.id);
      const isCurrent = state.currentLevel === lvl.id;
      const label = document.createElement('div');
      label.textContent = `${lvl.name}${isCurrent ? ' (active)' : ''}`;
      row.appendChild(label);

      if(unlocked){
        const btn = document.createElement('button');
        btn.className = 'secondary';
        btn.textContent = isCurrent ? 'Playing' : 'Play';
        btn.disabled = isCurrent;
        btn.onclick = ()=> startLevel(lvl.id);
        row.appendChild(btn);
      } else {
        const appliesDiscount = state.discount > 0 && lvl.id === nextLockedLevel.id;
        const discountedCost = appliesDiscount
          ? Math.max(0, Math.round(lvl.cost * (1 - state.discount)))
          : lvl.cost;
        const btn = document.createElement('button');
        btn.textContent = appliesDiscount
          ? `Unlock 🪙${discountedCost} (was ${lvl.cost})`
          : `Unlock 🪙${lvl.cost}`;
        btn.disabled = state.coins < discountedCost;
        btn.onclick = ()=>{
          if(state.coins >= discountedCost){
            state.coins -= discountedCost;
            state.unlocked.push(lvl.id);
            if(appliesDiscount){
              state.discount = 0; // voucher consumed
              document.getElementById('discountMsg').textContent = '';
            } else if(state.discount > 0){
              // voucher was available but not used on its eligible level — it expires
              state.discount = 0;
              document.getElementById('discountMsg').textContent = '';
            }
            showToast(`🔓 Unlocked ${lvl.name}!`);
            startLevel(lvl.id);
          }
        };
        row.appendChild(btn);
      }
      levelListEl.appendChild(row);
    });
  }

  document.getElementById('shuffleBtn').onclick = ()=> startLevel(state.currentLevel);

  document.getElementById('hintBtn').onclick = ()=>{
    if(state.coins < 5){
      showToast("Not enough coins for a hint!");
      return;
    }
    state.coins -= 5;
    // find a tile adjacent to empty that moves it closer to solved position (simple heuristic)
    const size = state.size;
    const empty = state.emptyIndex;
    const erow = Math.floor(empty/size), ecol = empty%size;
    const neighbors = [];
    if(erow>0) neighbors.push(empty-size);
    if(erow<size-1) neighbors.push(empty+size);
    if(ecol>0) neighbors.push(empty-1);
    if(ecol<size-1) neighbors.push(empty+1);
    let best = null, bestScore = -1;
    neighbors.forEach(n=>{
      const val = state.tiles[n];
      const targetIdx = val - 1; // 1 goes to index0, etc.
      const curDist = Math.abs(Math.floor(n/size)-Math.floor(targetIdx/size)) + Math.abs(n%size - targetIdx%size);
      const newDist = Math.abs(Math.floor(empty/size)-Math.floor(targetIdx/size)) + Math.abs(empty%size - targetIdx%size);
      const score = curDist - newDist;
      if(score > bestScore){ bestScore = score; best = n; }
    });
    if(best !== null) tryMove(best);
    render();
  };

  document.getElementById('nameStartBtn').onclick = ()=>{
    const input = document.getElementById('nameInput');
    const val = input.value.trim();
    state.playerName = val || 'Player';
    document.getElementById('nameOverlay').classList.remove('show');
    startLevel(1);
  };
  document.getElementById('nameInput').addEventListener('keydown', (e)=>{
    if(e.key === 'Enter') document.getElementById('nameStartBtn').click();
  });
})();
</script>
</body>
</html>
